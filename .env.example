# 默认 /api 走 Vite 代理到 https://api.celing.cc（见 vite.config.ts）
# 生产构建可设为完整地址，例如：https://api.celing.cc
VITE_API_BASE_URL=/api

# 为 true 时登录不请求后端，使用本地 mock token（仅离线演示）
# VITE_USE_MOCK_ADMIN_AUTH=false

# 为 true 时转账明细页仍用内置 Mock 表格，不请求 /admin/transaction/list
# VITE_USE_ADMIN_MOCK_DATA=false

# 为 true 时「用户管理 / 用户详情」使用本地演示数据，不请求 /admin/user/*
# VITE_USE_END_USER_MOCK=false
